# Supabase — copy this file to .env.local and fill in values from
# https://supabase.com/dashboard/project/qbesmdxntzrbzlwfbqmy/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://qbesmdxntzrbzlwfbqmy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by migration scripts and server-side admin operations
# (inviting new admin users, password recovery, etc).
# Get from the same API Keys page (the "secret" key) and from the Connect panel.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Public site URL — used as the redirect target in invite/recovery emails.
# Defaults to https://idealcarsltd.co.nz if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — used for transactional emails (admin notifications when a
# customer submits a contact or sell-car enquiry). Get from
# https://resend.com/api-keys
RESEND_API_KEY=
# Optional: override the From address for outgoing notifications.
# Defaults to "Ideal Cars <noreply@idealcarsltd.co.nz>".
EMAIL_FROM=
# Optional: From address for emails the customer should reply to (admin replies
# to enquiries). Must be on the verified sending domain. Avoids "noreply".
# Defaults to "Ideal Cars <enquiries@idealcarsltd.co.nz>".
EMAIL_REPLY_FROM=
# Optional: where customer replies are routed (Reply-To header).
# Defaults to idealcarsnzltd@gmail.com.
EMAIL_REPLY_TO=

# CarJam vehicle lookup (https://www.carjam.co.nz/dev:page?t=vehicle-queries)
CARJAM_API_KEY=
# Optional: point at the test environment while trialling
# CARJAM_API_BASE=https://test.carjam.co.nz/api/car/
