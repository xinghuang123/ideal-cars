# Supabase — copy this file to .env.local and fill in values from
# https://supabase.com/dashboard/project/qbesmdxntzrbzlwfbqmy/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://qbesmdxntzrbzlwfbqmy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by migration scripts and server-side admin operations
# (inviting new admin users, password recovery, etc).
# Get from the same API Keys page (the "secret" key) and from the Connect panel.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Public site URL — used as the redirect target in invite/recovery emails.
# Defaults to https://idealcarsltd.co.nz if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
